# .env.example — NiteOS local development environment variables
#
# Copy this file to .env and fill in values as needed for local development.
# Production values are NEVER stored here. Production uses Docker secrets (files).
# See docs/SECRET_ROTATION.md for production secret management.
#
# .env is gitignored. Never commit a file named .env or .env.local.

# ─── Database ────────────────────────────────────────────────────────────────
# For local dev: matches infra/docker-compose.dev.yml defaults.
DATABASE_URL=postgres://niteos:devpassword@localhost:5432/niteos?sslmode=disable

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:devpassword@localhost:6379

# ─── JWT (auth service only) ─────────────────────────────────────────────────
# In production these are Docker secrets (files). Locally, point at infra/secrets/.
# Run: openssl genrsa -out infra/secrets/jwt_private_key.pem 2048
# Run: openssl rsa -in infra/secrets/jwt_private_key.pem -pubout -out infra/secrets/jwt_public_key.pem
JWT_PRIVATE_KEY_FILE=infra/secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_FILE=infra/secrets/jwt_public_key.pem

# ─── Service discovery (set per-service; shown here for reference) ───────────
# Each service only knows the URLs of services it calls.
PROFILES_SERVICE_URL=http://localhost:8020
LEDGER_SERVICE_URL=http://localhost:8030
WALLET_SERVICE_URL=http://localhost:8040
TICKETING_SERVICE_URL=http://localhost:8050
PAYMENTS_SERVICE_URL=http://localhost:8060
DEVICES_SERVICE_URL=http://localhost:8070
CATALOG_SERVICE_URL=http://localhost:8080
ORDERS_SERVICE_URL=http://localhost:8090
SESSIONS_SERVICE_URL=http://localhost:8100
SYNC_SERVICE_URL=http://localhost:8110
REPORTING_SERVICE_URL=http://localhost:8120
AUTH_SERVICE_URL=http://localhost:8010
GATEWAY_SERVICE_URL=http://localhost:8000

# ─── Payment providers (payments service only) ───────────────────────────────
# Use Stripe test mode keys for local development.
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# TWINT_API_KEY= (not available until Swiss business account established)

# ─── Edge (edge service only) ────────────────────────────────────────────────
CLOUD_SYNC_URL=http://localhost:8110
EDGE_TOKEN_FILE=infra/secrets/edge_token.toml

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=debug
SERVICE_NAME=local
