# NiteOS Cloud Production Environment — VPS A
# ──────────────────────────────────────────────
# Copy to infra/cloud.env on the VPS and fill in ALL values.
# NEVER commit infra/cloud.env — it is gitignored.
# Generate passwords: openssl rand -base64 32
#
# Deployment: docker compose -f infra/docker-compose.cloud.yml --env-file infra/cloud.env up -d

# ── Domains ───────────────────────────────────────────────────────────────────
DOMAIN=niteos.io
ACME_EMAIL=admin@niteos.io

# ── Traefik port offset (staged coexistence with existing nginx) ──────────────
# nginx holds :80/:443 on VPS A for market/more/radio/stream.peoplewelike.club.
# Traefik runs on :8080/:8443 until nginx is decommissioned.
#
# STAGING (now):  TRAEFIK_PORT_SUFFIX=:8443
# PRODUCTION:     TRAEFIK_PORT_SUFFIX=   (empty string — remove the value, not the key)
#
# Also update infra/traefik/traefik.yml entryPoints at cutover:
#   web:      address: ":80"
#   websecure: address: ":443"
# And infra/docker-compose.cloud.yml Traefik ports:
#   - "80:80"
#   - "443:443"
TRAEFIK_PORT_SUFFIX=:8443

# ── Cloudflare DNS-01 TLS ─────────────────────────────────────────────────────
# Traefik uses Cloudflare DNS-01 challenge for Let's Encrypt (required for Cloudflare-proxied domains).
# Create API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone > DNS > Edit, Zone > Zone > Read
CF_DNS_API_TOKEN=REPLACE_WITH_CLOUDFLARE_API_TOKEN

# ── Traefik dashboard (htpasswd format, generate with: htpasswd -nB admin) ───
TRAEFIK_DASHBOARD_USERS=admin:$$2y$$10$$REPLACE_WITH_HTPASSWD_HASH

# ── Postgres ──────────────────────────────────────────────────────────────────
# Used by postgres service init AND as part of DATABASE_URL for all services.
POSTGRES_PASSWORD=CHANGEME_use_openssl_rand_base64_32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGEME_use_openssl_rand_base64_32

# ── Auth service — JWT signing key ───────────────────────────────────────────
# Generate:
#   mkdir -p infra/secrets
#   openssl genrsa -out infra/secrets/jwt_private_key.pem 2048
#   openssl rsa -in infra/secrets/jwt_private_key.pem -pubout -out infra/secrets/jwt_public_key.pem
# The compose file mounts infra/secrets/jwt_private_key.pem as a bind volume.
# (Path used by auth service: JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key.pem)

# ── Payments — Stripe ─────────────────────────────────────────────────────────
# Use live keys for production; test keys for staging.
STRIPE_API_KEY=sk_live_REPLACE_WITH_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ── Admin console ─────────────────────────────────────────────────────────────
# SESSION_SECRET must be at least 32 random characters.
SESSION_SECRET=CHANGEME_use_openssl_rand_base64_32

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGEME_use_openssl_rand_base64_32

# ── VPS A deployment notes ────────────────────────────────────────────────────
# 1. Provision VPS (Ubuntu 24.04 LTS, 4 vCPU, 8 GB RAM, 80 GB SSD recommended)
# 2. Install Docker: https://docs.docker.com/engine/install/ubuntu/
# 3. Clone repo: git clone git@github.com:ORG/final-event-platform.git
# 4. Copy this file: cp infra/cloud.env.example infra/cloud.env && nano infra/cloud.env
# 5. Create secrets dir: mkdir -p infra/secrets && chmod 700 infra/secrets
# 6. Generate JWT keys (see Auth service section above)
# 7. Create acme.json: touch infra/traefik/acme.json && chmod 600 infra/traefik/acme.json
# 8. Run migrations: docker compose -f infra/docker-compose.cloud.yml run --rm profiles \
#      sh -c "psql $DATABASE_URL -f /migrations/000_init_schemas.sql"
#    (or use scripts/migrate.sh with DATABASE_URL set)
# 9. Start stack: docker compose -f infra/docker-compose.cloud.yml up -d
# 10. Verify: docker compose -f infra/docker-compose.cloud.yml ps
# 11. During staged deploy: access via https://grafana.niteos.io:8443
#     After nginx cutover: https://grafana.niteos.io (standard port)
