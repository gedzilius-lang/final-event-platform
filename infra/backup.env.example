# NiteOS backup environment — copy to /opt/niteos/backup.env on VPS A
# NEVER commit backup.env — it contains the DATABASE_URL with credentials.
#
# Install systemd units:
#   cp infra/systemd/niteos-backup.{service,timer} /etc/systemd/system/
#   systemctl daemon-reload
#   systemctl enable --now niteos-backup.timer
#   systemctl list-timers niteos-backup.timer

# Required: Postgres connection string
DATABASE_URL=postgres://niteos:CHANGEME@localhost:5432/niteos?sslmode=disable

# Optional: local retention (number of backups to keep)
BACKUP_RETENTION=14

# Optional: upload backend — rclone | awscli | none
BACKUP_UPLOAD=none

# Required if BACKUP_UPLOAD != none:
# rclone example:  BACKUP_REMOTE=r2:niteos-backups/pg
# awscli example:  BACKUP_REMOTE=s3://niteos-backups/pg
BACKUP_REMOTE=
